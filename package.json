{
  "name": "cz-school-sankey-starter",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run typecheck:api && vite build",
    "typecheck:api": "tsc -p tsconfig.api.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:prod": "node ./scripts/smoke-atlas-api.mjs",
    "preview": "vite preview",
    "db:up": "bash ./scripts/dev-db-up.sh",
    "db:down": "bash ./scripts/dev-db-down.sh",
    "db:url": "bash ./scripts/dev-db-url.sh",
    "db:apply:schema": "python3 db/apply_schema.py --database-url \"$(bash ./scripts/dev-db-url.sh)\"",
    "db:load:school:2025": "python3 etl/load_school_raw.py --year 2025 --database-url \"$(bash ./scripts/dev-db-url.sh)\"",
    "db:transform:school:2025": "python3 etl/transform_school_core.py --year 2025 --database-url \"$(bash ./scripts/dev-db-url.sh)\"",
    "db:load:health": "python3 etl/load_health_raw.py --database-url \"$(bash ./scripts/dev-db-url.sh)\"",
    "etl:demo": "python3 etl/build_school_year.py --year 2025 --demo",
    "etl:parse": "python3 etl/parse_msmt_xlsx.py --year 2025 --kraj Středočeský --top 25",
    "etl:eu": "python3 etl/fetch_eu_grants.py --year 2025",
    "etl:year": "python3 etl/build_school_year.py --year 2025",
    "etl:founders": "python3 etl/fetch_founder_budgets.py --year 2025",
    "etl:founders:columns": "python3 etl/fetch_founder_budgets.py --year 2025 --list-columns",
    "etl:registry": "python3 etl/fetch_msmt_registry.py --year 2025 --update-csv",
    "etl:full": "npm run etl:parse && npm run etl:eu && npm run etl:founders && npm run etl:registry && npm run etl:year",
    "health:providers": "python3 etl/health/fetch_provider_sites.py",
    "health:claims:providers": "python3 etl/health/fetch_claims_by_provider_specialty.py",
    "health:claims:providers:ico": "python3 etl/health/fetch_claims_by_provider_ico.py",
    "health:claims:payers": "python3 etl/health/fetch_claims_by_payer.py",
    "health:load:claims": "node ./scripts/load-health-claims-monthly.mjs",
    "health:insurers": "python3 etl/health/fetch_insurer_codebook.py",
    "health:monitor:pull": "python3 etl/health/fetch_monitor_indicators.py",
    "health:monitor:load": "python3 etl/load_health_raw.py --dataset health_monitor_indicators --database-url \"${DATABASE_URL}\"",
    "health:mz:pull": "python3 etl/health/fetch_mz_budget_entities.py",
    "health:mz:load": "python3 etl/load_health_raw.py --dataset health_mz_budget_entities --database-url \"${DATABASE_URL}\"",
    "health:financing:pull": "python3 etl/health/fetch_czso_health_financing.py",
    "health:financing:load": "python3 etl/load_health_raw.py --dataset health_financing_aggregates --database-url \"${DATABASE_URL}\"",
    "health:zzs:pull": "python3 etl/health/fetch_zzs_activity_aggregates.py",
    "health:zzs:load": "python3 etl/load_health_raw.py --dataset health_zzs_activity_aggregates --database-url \"${DATABASE_URL}\"",
    "social:mpsv:pull": "python3 etl/social/fetch_mpsv_budget_aggregates.py",
    "social:mpsv:load": "python3 etl/load_social_raw.py --dataset social_mpsv_aggregates --database-url \"${DATABASE_URL}\"",
    "social:recipients:pull": "python3 etl/social/fetch_recipient_metrics.py --year 2024",
    "social:recipients:load": "python3 etl/load_social_raw.py --dataset social_recipient_metrics --database-url \"${DATABASE_URL}\"",
    "mv:budget:pull": "python3 etl/mv/fetch_budget_aggregates.py",
    "mv:budget:load": "python3 etl/load_mv_raw.py --dataset mv_budget_aggregates --database-url \"${DATABASE_URL}\"",
    "mv:police:pull": "python3 etl/mv/fetch_police_crime_aggregates.py",
    "mv:police:load": "python3 etl/load_mv_raw.py --dataset mv_police_crime_aggregates --database-url \"${DATABASE_URL}\"",
    "mv:fire:pull": "python3 etl/mv/fetch_fire_rescue_activity_aggregates.py",
    "mv:fire:load": "python3 etl/load_mv_raw.py --dataset mv_fire_rescue_activity_aggregates --database-url \"${DATABASE_URL}\"",
    "justice:budget:pull": "python3 etl/justice/fetch_budget_aggregates.py",
    "justice:budget:load": "python3 etl/load_justice_raw.py --dataset justice_budget_aggregates --database-url \"${DATABASE_URL}\"",
    "justice:activity:pull": "python3 etl/justice/fetch_activity_aggregates.py --year 2024",
    "justice:activity:load": "python3 etl/load_justice_raw.py --dataset justice_activity_aggregates --database-url \"${DATABASE_URL}\"",
    "transport:budget:pull": "python3 etl/transport/fetch_budget_entities.py --year 2024 --year 2025",
    "transport:budget:load": "python3 etl/load_transport_raw.py --dataset transport_budget_entities --database-url \"${DATABASE_URL}\"",
    "transport:sfdi:pull": "python3 etl/transport/fetch_sfdi_projects.py --year 2024 --year 2025",
    "transport:sfdi:load": "python3 etl/load_transport_raw.py --dataset transport_sfdi_projects --database-url \"${DATABASE_URL}\"",
    "transport:activity:pull": "python3 etl/transport/fetch_activity_metrics.py --year 2024 --year 2025",
    "transport:activity:load": "python3 etl/load_transport_raw.py --dataset transport_activity_metrics --database-url \"${DATABASE_URL}\"",
    "agriculture:budget:pull": "python3 etl/agriculture/fetch_budget_entities.py --year 2024 --year 2025",
    "agriculture:budget:load": "python3 etl/load_agriculture_raw.py --dataset agriculture_budget_entities --database-url \"${DATABASE_URL}\"",
    "agriculture:subsidies:pull": "python3 etl/agriculture/fetch_szif_payments.py --year 2024",
    "agriculture:subsidies:load": "python3 etl/load_agriculture_raw.py --dataset agriculture_szif_payments --database-url \"${DATABASE_URL}\"",
    "agriculture:lpis:pull": "python3 etl/agriculture/fetch_lpis_user_area.py --year 2024",
    "agriculture:lpis:load": "python3 etl/load_agriculture_raw.py --dataset agriculture_lpis_user_area --database-url \"${DATABASE_URL}\"",
    "environment:budget:pull": "python3 etl/environment/fetch_budget_entities.py --year 2024 --year 2025",
    "environment:budget:load": "python3 etl/load_environment_raw.py --dataset environment_budget_entities --database-url \"${DATABASE_URL}\"",
    "environment:supports:pull": "python3 etl/environment/fetch_sfzp_supports.py --year 2024 --year 2025",
    "environment:supports:load": "python3 etl/load_environment_raw.py --dataset environment_sfzp_supports --database-url \"${DATABASE_URL}\"",
    "mmr:budget:pull": "python3 etl/mmr/fetch_budget_aggregates.py --year 2024 --year 2025",
    "mmr:budget:load": "python3 etl/load_mmr_raw.py --dataset mmr_budget_aggregates --database-url \"${DATABASE_URL}\"",
    "mmr:irop:pull": "python3 etl/mmr/fetch_irop_operations.py --year 2024 --year 2025",
    "mmr:irop:load": "python3 etl/load_mmr_raw.py --dataset mmr_irop_operations --database-url \"${DATABASE_URL}\"",
    "mpo:budget:pull": "python3 etl/mpo/fetch_budget_entities.py --year 2024 --year 2025",
    "mpo:budget:load": "python3 etl/load_mpo_raw.py --dataset mpo_budget_entities --database-url \"${DATABASE_URL}\"",
    "mpo:optak:pull": "python3 etl/mpo/fetch_optak_operations.py --year 2024 --year 2025",
    "mpo:optak:load": "python3 etl/load_mpo_raw.py --dataset mpo_optak_operations --database-url \"${DATABASE_URL}\"",
    "health:fetch:all": "npm run health:providers && npm run health:claims:providers && npm run health:claims:providers:ico && npm run health:claims:payers && npm run health:insurers"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
